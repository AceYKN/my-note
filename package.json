{
  "name": "my-note",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:clean": "node scripts/clean-vitepress.mjs",
    "docs:build": "npm run docs:clean && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "strip:span": "node scripts/remove-span-tags.mjs",
    "test:mermaid": "node scripts/check-mermaid-rendering.mjs",
    "test:learning": "node scripts/check-learning-progress.mjs",
    "test:outline-scroll-spy": "node scripts/check-outline-scroll-spy.mjs",
    "test:seo-ai": "node scripts/check-seo-ai-signals.mjs",
    "check": "npm run test:mermaid && npm run test:learning && npm run test:outline-scroll-spy && npm run docs:build && npm run test:seo-ai && npm run lint:check && npm run format:check && npm run style:check",
    "lint": "eslint \"docs/.vitepress/**/*.{js,mjs,vue}\" \"scripts/**/*.mjs\" --fix",
    "lint:check": "eslint \"docs/.vitepress/**/*.{js,mjs,vue}\" \"scripts/**/*.mjs\" --max-warnings=0",
    "format": "prettier --write \"docs/.vitepress/**/*.{js,mjs,vue,css}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"docs/.vitepress/**/*.{js,mjs,vue,css}\" \"scripts/**/*.mjs\"",
    "lint:css": "stylelint \"docs/.vitepress/**/*.css\" --fix",
    "style:check": "stylelint \"docs/.vitepress/**/*.css\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AceYKN/my-note.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AceYKN/my-note/issues"
  },
  "homepage": "https://github.com/AceYKN/my-note#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mdit/plugin-katex": "^1.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "katex": "^0.16.47",
    "lint-staged": "^17.0.8",
    "mermaid": "^11.15.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.34"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^7.0.0"
  },
  "lint-staged": {
    "docs/.vitepress/**/*.{js,mjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "scripts/**/*.mjs": [
      "eslint --fix"
    ],
    "docs/.vitepress/**/*.css": [
      "stylelint --fix"
    ]
  }
}
